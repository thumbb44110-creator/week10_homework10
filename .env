# Week 10 Homework: ARIA v7.0 - Environment Configuration
# ================================================

# 研究區設定 (花蓮馬太鞍溪流域)
BBOX_WEST=121.2574
BBOX_SOUTH=23.6546
BBOX_EAST=121.4984
BBOX_NORTH=23.7447

# 時間範圍設定 (2025年鳳凰颱風)
PRE_DATE_RANGE=2025-10-01/2025-11-05
POST_DATE_RANGE=2025-11-12/2025-11-30

# SAR 處理參數
SAR_THRESHOLD=-18      # ARIA 預設值；可根據直方圖分析調整
SAR_FILTER_SIZE=5     # Median filter size for speckle filtering

# 光學處理參數
NDWI_THRESHOLD=0.3    # 清水 ~0.3；濁水 ~0.0（依場景調整）
MAX_CLOUD_COVER=80    # 最大雲量百分比

# 地形分析參數
SLOPE_THRESHOLD=25     # 保守值；坡度 > 25° 判定為不可能積水
MIN_WATER_PIXELS=50    # Connected component 最小面積（50 px = 0.5 ha）

# 輸出設定
OUTPUT_DIR=output
FIGURE_DPI=300
FIGURE_SIZE=(12, 8)

# 坐標系統
TARGET_EPSG=32651     # UTM Zone 51N
RESOLUTION=10         # 10公尺解析度

# STAC API 設定
STAC_URL=https://planetarycomputer.microsoft.com/api/stac/v1
COLLECTION_SAR=sentinel-1-rtc
COLLECTION_OPTICAL=sentinel-2-l2a
COLLECTION_DEM=cop-dem-glo-30

# 處理參數
CHUNKSIZE=2048
MAX_RETRIES=3
TIMEOUT=60

# Gemini API 設定
GEMINI_API_KEY=AIzaSyCN9yKZ-m4d1ZkIThtMnvmQxMc1Jm3ybhc
